# Optional: enable later when applying LIVE_DEPLOYMENT_GOOGLE_OAUTH.md
SCANFIT_GOOGLE_CLIENT_ID=
SCANFIT_GOOGLE_CLIENT_SECRET=
SCANFIT_GOOGLE_REDIRECT_URI=
